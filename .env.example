# Puerto del servidor HTTP
PORT=3000

# =====================================================================
# Fuente de la matriz de mantenimiento
# Valores: local | googlesheet | onedrive
# Solo se necesitan las credenciales del proveedor seleccionado.
# =====================================================================
MATRIX_SOURCE=local

# ---- Proveedor: local (.xlsx) ----
# Ruta al archivo Excel. Por defecto el archivo de ejemplo del repo.
LOCAL_EXCEL_PATH=./Example_Excel/Insumos JCB 2026.xlsx

# ---- Proveedor: googlesheet ----
GOOGLE_SHEET_ID=
GOOGLE_CLIENT_EMAIL=
# Clave privada de la cuenta de servicio. Mantener las comillas y los \n literales.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Proveedor: onedrive (Microsoft Graph, client credentials) ----
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Identificación del archivo en OneDrive/SharePoint:
# opción recomendada: ONEDRIVE_DRIVE_ID + ONEDRIVE_ITEM_ID
# alternativa: ONEDRIVE_USER_ID + ONEDRIVE_ITEM_ID
ONEDRIVE_DRIVE_ID=
ONEDRIVE_USER_ID=
ONEDRIVE_ITEM_ID=

# =====================================================================
# HubSpot
# =====================================================================
# Private App Access Token con scopes de crm.objects.deals, line_items,
# products, companies y contacts (lectura/escritura).
HUBSPOT_ACCESS_TOKEN=

# Propiedad del producto usada para hacer match por número de parte (SKU).
HUBSPOT_PRODUCT_SKU_PROPERTY=hs_sku

# Propiedades de frecuencia (selección Si/No) en el line item.
HUBSPOT_FREQUENCY_100_PROPERTY=frec_100
HUBSPOT_FREQUENCY_250_PROPERTY=frec_250
HUBSPOT_FREQUENCY_500_PROPERTY=frec_500
HUBSPOT_FREQUENCY_1000_PROPERTY=frec_1000
HUBSPOT_FREQUENCY_2000_PROPERTY=frec_2000
HUBSPOT_FREQUENCY_8000_PROPERTY=frec_8000

# Valor enviado cuando la frecuencia tiene una "X" (las demás no se envían).
HUBSPOT_FREQUENCY_VALUE_YES=Si

# ---- Creación del nuevo deal (réplica del original) ----
# Pipeline por defecto donde se crea el nuevo negocio (obligatorio).
HUBSPOT_DEFAULT_DEAL_PIPELINE=default
# Etapa por defecto. Si se deja vacía se usa la primera etapa del pipeline.
HUBSPOT_DEFAULT_DEAL_STAGE=
# Sufijo agregado al nombre del deal original para nombrar el nuevo.
HUBSPOT_NEW_DEAL_NAME_SUFFIX= - Mantenimiento

# ---- IDs de tipos de asociación (HubSpot defined) ----
HUBSPOT_DEAL_TO_COMPANY_ASSOCIATION_TYPE_ID=5
HUBSPOT_DEAL_TO_CONTACT_ASSOCIATION_TYPE_ID=3
HUBSPOT_LINE_ITEM_TO_DEAL_ASSOCIATION_TYPE_ID=20
