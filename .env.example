# Puerto del servidor HTTP
PORT=3000

# ---- HubSpot ----
# Private App Access Token con scopes de crm.objects.deals, crm.objects.line_items y crm.objects.products
HUBSPOT_ACCESS_TOKEN=

# Propiedad del line item donde está guardado el código de máquina
HUBSPOT_MACHINE_CODE_PROPERTY=codigo_maquina
# Propiedad del producto donde está guardado el número de parte
HUBSPOT_PRODUCT_PART_NUMBER_PROPERTY=numero_parte

# Propiedades de frecuencia (selección Si/No) en el line item
HUBSPOT_FREQUENCY_250_PROPERTY=frecuencia_250
HUBSPOT_FREQUENCY_500_PROPERTY=frecuencia_500
HUBSPOT_FREQUENCY_1000_PROPERTY=frecuencia_1000
HUBSPOT_FREQUENCY_2000_PROPERTY=frecuencia_2000
HUBSPOT_FREQUENCY_3000_PROPERTY=frecuencia_3000
HUBSPOT_FREQUENCY_5000_PROPERTY=frecuencia_5000

# Valores que se enviarán a las propiedades de frecuencia
HUBSPOT_FREQUENCY_VALUE_YES=Si
HUBSPOT_FREQUENCY_VALUE_NO=No

# Propiedades de control para evitar duplicados
HUBSPOT_MAINTENANCE_GENERATED_PROPERTY=maintenance_generated
HUBSPOT_MAINTENANCE_SOURCE_MACHINE_CODE_PROPERTY=maintenance_source_machine_code
HUBSPOT_MAINTENANCE_PART_NUMBER_PROPERTY=maintenance_part_number

# ID del tipo de asociación line_item -> deal (HubSpot defined). Por defecto 20.
HUBSPOT_LINE_ITEM_TO_DEAL_ASSOCIATION_TYPE_ID=20

# ---- Google Sheets ----
# ID del Google Sheet (lo que aparece en la URL entre /d/ y /edit)
GOOGLE_SHEET_ID=
# Email de la cuenta de servicio
GOOGLE_CLIENT_EMAIL=
# Clave privada de la cuenta de servicio. Mantener las comillas y los \n literales.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
